<Page x:Class="Project2Crafting.CraftingInterface"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Project2Crafting"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CraftingInterface" Foreground="Red">

    <Grid Loaded="Grid_Loaded">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF960000" Offset="1"/>
                <GradientStop Color="#FF210101"/>
            </LinearGradientBrush>
        </Grid.Background>
        <TextBlock x:Name="InventoryNameText" HorizontalAlignment="Left" Margin="442,10,0,0" Text="Inventory" VerticalAlignment="Top" Height="40" Width="348" TextAlignment="Center" FontSize="36" FontFamily="MS Gothic"/>
        <Button x:Name="CraftRecipeButton" Content="Craft" Margin="330,400,0,0" Foreground="Red" Background="Black" FontFamily="MS Gothic" FontSize="18" BorderBrush="Red" FontWeight="Bold" Click="CraftRecipeButton_Click" Height="28" VerticalAlignment="Top" HorizontalAlignment="Left" Width="99"/>
        <Button x:Name="BuyItemButton" Content="Buy" HorizontalAlignment="Left" Margin="330,400,0,0" VerticalAlignment="Top" Height="28" Width="99" Foreground="Red" Background="Black" FontFamily="MS Gothic" FontSize="24" BorderBrush="Red" Click="BuyItemButton_Click"/>
        <ScrollViewer x:Name="Inventory" Margin="442,55,10,10" VerticalScrollBarVisibility="Auto" BorderBrush="White" Background="Black">
            <TextBlock x:Name="InventoryText" TextWrapping="Wrap" Foreground="White"/>
        </ScrollViewer>
        <ScrollViewer x:Name="ItemBox" Margin="10,104,371,66" Background="Black" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="ItemBoxText" TextWrapping="Wrap" Foreground="White"/>
        </ScrollViewer>
        <TextBox x:Name="Input" HorizontalAlignment="Left" Margin="10,400,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="315" Height="28" Background="Black" Foreground="White" BorderBrush="White"/>
        <TextBlock x:Name="CurrencyText" HorizontalAlignment="Left" Margin="31,30,0,0" Text="Money:" VerticalAlignment="Top" Height="40" Width="137" TextAlignment="Center" FontSize="36" FontFamily="MS Gothic"/>
        <Label x:Name="CurrencyLabel" Content="$0.00" HorizontalAlignment="Left" Margin="157,26,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontSize="36" Height="48" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="MS Gothic" Width="103"/>

    </Grid>
</Page>
